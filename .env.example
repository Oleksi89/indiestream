# .env.example
SPRING_PROFILES_ACTIVE=prod,seeder

# PostgreSQL Database Configuration
POSTGRES_USER=indiestream_user
POSTGRES_PASSWORD=your_secure_db_password
POSTGRES_DB=indiestream_database

# MinIO Storage Configuration
MINIO_ROOT_USER=indiestream_user
MINIO_ROOT_PASSWORD=your_secure_minio_password

# Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key

# OpenAI API Configuration (Vector Embeddings text-embedding-3-small)
OPENAI_API_KEY=your_openai_api_key

# JWT Configuration
JWT_SECRET=your_jwt_secret

# CORS
CORS_ALLOWED_ORIGINS=your_jwt_secret

# VPS Configuration
VPS_HOST=your_vps_host_ip
VPS_USER=your_vps_user
VPS_SSH_KEY=your_ssh_key